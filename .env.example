# Copy to Dokploy environment variables (do NOT commit real secrets)

SECRET_KEY=generate-a-long-random-string-here
SERVER_PUBLIC_URL=https://dayz-map.gto-team.uz

# Pripyat map world bounds — tune after calibration
MAP_MIN_X=0
MAP_MAX_X=15360
MAP_MIN_Y=0
MAP_MAX_Y=15360

# Path inside container (volume /data)
CLIENT_EXE_PATH=/data/DayZMapClient.exe
